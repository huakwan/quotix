{
  "name": "quotix",
  "version": "1.0.6",
  "description": "Show Claude Code and Codex usage quota in the macOS menu bar.",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "compile": "node esbuild.js",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsc --outDir out && node --test tests/*.test.mjs",
    "test": "pnpm run test:unit",
    "watch": "node esbuild.js --watch",
    "start": "npm run compile && electron .",
    "dist:mac": "npm run compile && electron-builder --mac --universal --dir"
  },
  "build": {
    "appId": "com.huakwan.quotix",
    "productName": "Quotix",
    "directories": {
      "output": "release"
    },
    "files": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "package.json"
        ]
      },
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*",
          "!**/*.map",
          "!mac-*/**"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "anthropic.svg",
          "openai.svg"
        ]
      }
    ],
    "electronLanguages": [
      "en",
      "th"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": "dir",
      "category": "public.app-category.utilities",
      "minimumSystemVersion": "12.0",
      "identity": "-",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "yauzl": "^3.4.0"
  }
}

{
  "name": "quotix",
  "version": "0.1.0",
  "description": "Show Claude Code usage quota in the macOS menu bar.",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "start": "npm run compile && electron .",
    "dist:mac": "npm run compile && electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.huakwan.quotix",
    "productName": "Quotix",
    "files": ["dist/**/*", "assets/**/*"],
    "mac": {
      "target": "dir",
      "category": "public.app-category.utilities",
      "extendInfo": { "LSUIElement": true }
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
